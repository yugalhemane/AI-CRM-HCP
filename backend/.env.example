## Groq
GROQ_API_KEY=your_groq_key_here
# IMPORTANT: The assignment mentions `gemma2-9b-it`, but Groq may deprecate models.
# Set GROQ_MODEL to a currently supported Groq model from the Groq console.
GROQ_MODEL=llama-3.1-8b-instant

## Database (REQUIRED: use Postgres/MySQL for submission)
# Postgres example:
# DATABASE_URL=postgresql+psycopg2://postgres:postgres@localhost:5432/hcp_crm
#
# MySQL example:
# DATABASE_URL=mysql+pymysql://root:root@localhost:3306/hcp_crm
#
# Local fallback (ok for dev only, NOT for final submission):
# DATABASE_URL=sqlite:///./hcp_crm.db
